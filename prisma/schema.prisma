// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  stripeCustomerId  String?   @unique
  plan          String    @default("free") // free | maker | studio
  projectCount  Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  projects      Project[]

  @@map("users")
}

model Project {
  id           String   @id @default(cuid())
  name         String
  status       String   @default("idle")
  githubRepo   String?
  vercelUrl    String?
  researchData Json?
  ideas        Json?
  selectedIdea Json?
  events       Json     @default("[]")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("projects")
}
