# SaaS Generator Tool — Local Development Environment
# Copy this file to .env.local and fill in your actual values

# ─── AI Research ───────────────────────────────────────
EXA_API_KEY=sk-placeholder

# ─── Stripe Billing ──────────────────────────────────
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
STRIPE_PRICE_MAKER=price_maker_placeholder
STRIPE_PRICE_STUDIO=price_studio_placeholder

# ─── Vercel ──────────────────────────────────────────
VERCEL_API_TOKEN=placeholder

# ─── Email (Resend) ──────────────────────────────────
RESEND_API_KEY=re_placeholder
EMAIL_FROM=SaaS Generator <hello@saasgenerator.dev>

# ─── NextAuth ───────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=dev-secret-do-not-use-in-production-32chars
NEXTAUTH_URL=http://localhost:3457
GOOGLE_CLIENT_ID=placeholder
GOOGLE_CLIENT_SECRET=placeholder

# ─── Database ────────────────────────────────────────
DATABASE_URL=postgresql://placeholder:placeholder@host.db.supabase.co:5432/postgres

# ─── Public ──────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PRICE_MAKER=price_maker_placeholder
NEXT_PUBLIC_STRIPE_PRICE_STUDIO=price_studio_placeholder
NEXT_PUBLIC_APP_URL=http://localhost:3457
