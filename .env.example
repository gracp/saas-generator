# SaaS Generator Tool — Environment Variables

# ─── AI Research ───────────────────────────────────────
EXA_API_KEY=your_exa_api_key_here

# ─── Stripe Billing ─────────────────────────────────────
# Get from: dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_live_xxx
# Get from: dashboard.stripe.com → Webhooks → add endpoint → copy signing secret
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Get from: dashboard.stripe.com → Products → Create Product → copy Price ID
STRIPE_PRICE_MAKER=price_xxx        # $29/mo subscription
STRIPE_PRICE_STUDIO=price_xxx       # $99/mo subscription

# ─── Vercel Deployment ──────────────────────────────────
VERCEL_API_TOKEN=your_vercel_token_here

# ─── Email (Resend) ────────────────────────────────────
# Get from: resend.com → API Keys
RESEND_API_KEY=re_xxx
EMAIL_FROM=SaaS Generator <hello@yourdomain.com>

# ─── NextAuth / Authentication ─────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3457        # Update to your Vercel URL in production
# Get from: console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ─── Database (Supabase PostgreSQL) ─────────────────────
# Get from: Supabase → Project Settings → Connection String → URI
DATABASE_URL=postgresql://user:password@host.db.supabase.co:5432/postgres

# ─── Public (safe to expose) ────────────────────────────
NEXT_PUBLIC_STRIPE_PRICE_MAKER=price_xxx
NEXT_PUBLIC_STRIPE_PRICE_STUDIO=price_xxx
